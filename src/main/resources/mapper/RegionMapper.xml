<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demo.dronebackend.mapper.RegionMapper">

    <resultMap id="BaseResultMap" type="com.demo.dronebackend.pojo.Region">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="time" column="time" jdbcType="TIMESTAMP"/>
            <result property="type" column="type" jdbcType="TINYINT"/>
            <result property="userId" column="user_id" jdbcType="BIGINT"/>
            <result property="centerLon" column="center_lon" jdbcType="DOUBLE"/>
            <result property="centerLat" column="center_lat" jdbcType="DOUBLE"/>
            <result property="radius" column="radius" jdbcType="DOUBLE"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,time,type,
        user_id,center_lon,center_lat,
        radius
    </sql>
</mapper>
